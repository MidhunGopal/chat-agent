# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model Configuration
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# SQLite Persistent DB
SQLITE_DB_PATH=./data/insurance_hub.db

# Chunk Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
